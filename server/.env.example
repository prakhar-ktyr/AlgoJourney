# Copy to server/.env and fill in real values. Do not commit server/.env.

# Port the Express server listens on
PORT=5000

# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/algojourney

# development | production | test
NODE_ENV=development

# Allowed CORS origin in production (e.g. https://prakhar-ktyr.github.io)
# Required only when NODE_ENV=production.
CLIENT_URL=
